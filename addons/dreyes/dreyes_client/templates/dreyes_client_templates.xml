<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="client_assets" inherit_id="web.frontend_layout" priority="20">
        <xpath expr="//head" position="inside">
            <t t-if="request and request.httprequest and request.httprequest.path.startswith('/my')">
                <link rel="stylesheet" href="/dreyes_client/static/lib/tabler/css/tabler.min.css"/>
                <link rel="stylesheet" href="/dreyes_client/static/lib/tabler-icons/css/tabler-icons.min.css"/>
                <script type="text/javascript" src="/dreyes_client/static/lib/tabler/js/tabler.min.js"/>
            </t>
        </xpath>
    </template>

    <template id="portal_my_home_modern" inherit_id="portal.portal_my_home" priority="30">
        <xpath expr="//*[hasclass('o_portal_my_home')]" position="attributes">
            <attribute name="class" add="dc-portal-home" separator=" "/>
        </xpath>
        <xpath expr="//*[hasclass('o_portal_docs')]" position="before">
            <section class="dc-home-hero">
                <div class="dc-home-hero__main card">
                    <div class="card-body">
                        <div class="dc-home-hero__eyebrow">Portal del cliente</div>
                        <h1 class="dc-home-hero__title">Mi cuenta</h1>
                        <p class="dc-home-hero__copy">Consulta tus documentos, actividad comercial y datos de contacto desde un panel unificado.</p>

                        <div class="dc-home-hero__stats">
                            <div class="dc-stat-chip">
                                <span class="dc-stat-chip__label">Ventas recientes</span>
                                <strong><t t-esc="dreyes_client_total_sales_text or '$0.00'"/></strong>
                            </div>
                            <div class="dc-stat-chip">
                                <span class="dc-stat-chip__label">Saldo pendiente</span>
                                <strong><t t-esc="dreyes_client_total_due_text or '$0.00'"/></strong>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="dc-home-profile card">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-3">
                            <div class="avatar avatar-xl dc-avatar">
                                <t t-esc="(dreyes_client_partner.name or request.env.user.name or 'C')[:1]"/>
                            </div>
                            <div>
                                <div class="text-secondary text-uppercase small">Cliente</div>
                                <div class="fw-bold"><t t-esc="dreyes_client_partner.name or request.env.user.name"/></div>
                            </div>
                        </div>

                        <div class="dc-profile-list mt-4">
                            <div>
                                <span>Email</span>
                                <strong><t t-esc="dreyes_client_partner.email or request.env.user.login or '-'"/></strong>
                            </div>
                            <div>
                                <span>Telefono</span>
                                <strong><t t-esc="dreyes_client_partner.phone or dreyes_client_partner.mobile or '-'"/></strong>
                            </div>
                            <div>
                                <span>Direccion</span>
                                <strong><t t-esc="dreyes_client_partner.contact_address or '-'"/></strong>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </xpath>
        <xpath expr="//*[hasclass('o_portal_docs')]" position="attributes">
            <attribute name="class" add="row row-cards g-3 dc-home-docs" separator=" "/>
        </xpath>
        <xpath expr="//*[hasclass('o_portal_docs')]" position="after">
            <div class="row row-cards mt-2">
                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Ordenes recientes</h3>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-vcenter card-table">
                                <thead>
                                    <tr>
                                        <th>Orden</th>
                                        <th>Fecha</th>
                                        <th class="text-end">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-if="not dreyes_client_recent_orders">
                                        <td colspan="3" class="text-center text-secondary py-5">No hay ordenes recientes.</td>
                                    </tr>
                                    <tr t-foreach="dreyes_client_recent_orders" t-as="order">
                                        <td class="fw-semibold"><t t-esc="order.name"/></td>
                                        <td><span t-field="order.date_order" t-options='{"widget": "date"}'/></td>
                                        <td class="text-end"><span t-field="order.amount_total" t-options='{"widget": "monetary", "display_currency": order.currency_id}'/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Facturas recientes</h3>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-vcenter card-table">
                                <thead>
                                    <tr>
                                        <th>Factura</th>
                                        <th>Fecha</th>
                                        <th class="text-end">Residual</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-if="not dreyes_client_recent_invoices">
                                        <td colspan="3" class="text-center text-secondary py-5">No hay facturas recientes.</td>
                                    </tr>
                                    <tr t-foreach="dreyes_client_recent_invoices" t-as="invoice">
                                        <td class="fw-semibold"><t t-esc="invoice.name"/></td>
                                        <td><span t-field="invoice.invoice_date" t-options='{"widget": "date"}'/></td>
                                        <td class="text-end"><span t-field="invoice.amount_residual" t-options='{"widget": "monetary", "display_currency": invoice.currency_id}'/></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <template id="portal_docs_entry_modern" inherit_id="portal.portal_docs_entry" priority="30">
        <xpath expr="//a[@t-att-href='url']" position="attributes">
            <attribute name="class">card card-link dc-doc-card h-100 text-decoration-none</attribute>
        </xpath>
        <xpath expr="//a[@t-att-href='url']/*[1]" position="before">
            <div class="dc-doc-card__top">
                <span class="dc-doc-card__icon">
                    <i class="ti ti-layout-grid-add"/>
                </span>
                <span t-if="placeholder_count" class="badge bg-primary-lt rounded-pill" t-att-data-placeholder_count="placeholder_count"/>
            </div>
        </xpath>
    </template>
</odoo>
