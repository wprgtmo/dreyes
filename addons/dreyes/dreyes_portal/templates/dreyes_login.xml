<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_hide_header_footer_auth_pages" inherit_id="web.frontend_layout" priority="1">
        <xpath expr="//header[@id='top']" position="attributes">
            <attribute name="t-if">request.httprequest.path not in ['/web/login', '/web/signup', '/web/reset_password']</attribute>
        </xpath>
        <xpath expr="//footer[@id='bottom']" position="attributes">
            <attribute name="t-if">request.httprequest.path not in ['/web/login', '/web/signup', '/web/reset_password']</attribute>
        </xpath>
    </template>

    <template id="portal_web_login" inherit_id="web.login" name="DReyes Portal Login">
        <xpath expr="//t[@t-call='web.login_layout']" position="replace">
            <t t-call="web.frontend_layout">
                <t t-set="no_header" t-value="True"/>
                <t t-set="no_footer" t-value="True"/>

                <t t-call="dreyes_portal.portal_auth_base_layout">
                    <t t-set="auth_title" t-value="request.website.dreyes_auth_login_title or 'Bienvenido a su tienda'"/>
                    <t t-set="auth_subtitle" t-value="request.website.dreyes_auth_login_subtitle or 'Inicia sesion para continuar comprando.'"/>

                    <form class="oe_login_form" role="form" t-attf-action="/web/login{{ '?db=' + db if db else '' }}" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input t-if="redirect" type="hidden" name="redirect" t-att-value="redirect"/>

                        <div class="mb-3">
                            <label class="form-label fw-bold sd_text_blue small"><t>USUARIO</t></label>
                            <input type="text" name="login" t-att-value="login" class="form-control form-control-lg sd_input" required="required" autofocus="autofocus"/>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold sd_text_blue small"><t>CONTRASENA</t></label>
                            <input type="password" name="password" class="form-control form-control-lg sd_input" required="required" autocomplete="current-password"/>
                        </div>

                        <div t-if="recaptcha_site_key" class="mb-3">
                            <div class="g-recaptcha" t-att-data-sitekey="recaptcha_site_key"/>
                        </div>

                        <t t-if="error">
                            <div class="alert alert-danger shadow-sm border-0 mb-4" role="alert">
                                <i class="fa fa-exclamation-triangle me-2"/>
                                <t t-esc="error"/>
                            </div>
                        </t>

                        <t t-if="message">
                            <div class="alert alert-success shadow-sm border-0 mb-4" role="alert">
                                <i class="fa fa-check-circle me-2"/>
                                <t t-esc="message"/>
                            </div>
                        </t>

                        <button type="submit" class="btn btn-primary w-100 py-3 fw-bold sd_btn_blue shadow-sm mb-3"><t>ENTRAR</t></button>

                        <div class="o_login_auth text-center mb-4"/>

                        <div class="mt-4 pt-4 border-top d-flex flex-column gap-3 w-100">
                            <t t-if="signup_enabled">
                                <a t-attf-href="/web/signup{{ '?db=' + db if db else '' }}" class="btn btn-outline-danger w-100 fw-bold py-2">
                                    <t>Crear nueva cuenta</t>
                                </a>
                            </t>
                            <a t-if="reset_password_enabled" t-attf-href="/web/reset_password{{ '?db=' + db if db else '' }}" class="text-muted small fw-bold text-center text-decoration-none py-2">
                                <t>Has olvidado tu contrasena?</t>
                            </a>
                        </div>
                    </form>
                </t>
            </t>
        </xpath>
    </template>
</odoo>
