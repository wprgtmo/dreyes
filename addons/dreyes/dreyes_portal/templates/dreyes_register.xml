<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_web_signup" inherit_id="auth_signup.signup" name="Registro del portal DReyes">
        <xpath expr="//t[@t-call='web.login_layout']" position="replace">
            <t t-call="web.frontend_layout">
                <t t-set="no_header" t-value="True"/>
                <t t-set="no_footer" t-value="True"/>

                <t t-call="dreyes_portal.portal_auth_base_layout">
                    <t t-set="auth_title" t-value="request.website.dreyes_auth_signup_title or 'Crea tu cuenta'"/>
                    <t t-set="auth_subtitle" t-value="request.website.dreyes_auth_signup_subtitle or 'Unete a DReyes.'"/>

                    <form class="oe_signup_form" role="form" method="post" t-if="not message">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                        <div class="mb-3 field-name">
                            <label for="name" class="form-label fw-bold sd_text_blue small"><t>TU NOMBRE</t></label>
                            <input type="text" name="name" t-att-value="name" id="name" class="form-control form-control-lg sd_input" placeholder="Ej. Juan Perez" autofocus="autofocus" required="required" t-att-readonly="'readonly' if only_passwords else None" t-att-autofocus="'autofocus' if login and not name else None"/>
                        </div>

                        <div class="mb-3 field-login">
                            <label for="login" class="form-label fw-bold sd_text_blue small"><t>CORREO ELECTRONICO</t></label>
                            <input type="text" name="login" t-att-value="login" id="login" class="form-control form-control-lg sd_input" placeholder="nombre@ejemplo.com" required="required" t-att-readonly="'readonly' if only_passwords else None"/>
                        </div>

                        <div class="mb-3 field-password">
                            <label for="password" class="form-label fw-bold sd_text_blue small"><t>CONTRASENA</t></label>
                            <input type="password" name="password" id="password" class="form-control form-control-lg sd_input" required="required" t-att-autofocus="'autofocus' if login and name else None"/>
                        </div>

                        <div class="mb-3 field-confirm_password">
                            <label for="confirm_password" class="form-label fw-bold sd_text_blue small"><t>CONFIRMAR CONTRASENA</t></label>
                            <input type="password" name="confirm_password" id="confirm_password" class="form-control form-control-lg sd_input" required="required"/>
                        </div>

                        <p class="alert alert-danger" t-if="error" role="alert">
                            <t t-esc="error"/>
                        </p>

                        <input type="hidden" name="redirect" t-att-value="redirect"/>
                        <input type="hidden" name="token" t-att-value="token"/>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary w-100 py-3 fw-bold sd_btn_blue shadow-sm mb-3"><t>REGISTRARSE</t></button>
                        </div>

                        <div class="o_login_auth text-center mb-4"/>

                        <div class="mt-4 pt-4 border-top text-center">
                            <p class="text-muted small"><t>Ya tienes una cuenta?</t></p>
                            <a t-attf-href="/web/login?{{ keep_query() }}" class="btn btn-outline-danger w-100 fw-bold py-2">
                                <t>Iniciar sesion</t>
                            </a>
                        </div>
                    </form>

                    <div t-if="message" class="text-center">
                        <p class="alert alert-success" role="status">
                            <t t-esc="message"/>
                        </p>
                        <a t-attf-href="/web/login?{{ keep_query() }}" class="btn btn-primary w-100 py-3 fw-bold sd_btn_blue shadow-sm"><t>Volver al inicio</t></a>
                    </div>
                </t>
            </t>
        </xpath>
    </template>
</odoo>
